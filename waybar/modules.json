{
  "custom/notification": {
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "none": "",
      "notification": "󰂞",
      "dnd": "󰪑",
      "dnd-none": "󰪑",
      "dnd-notification": "󰪑"
    },
    "tooltip": false,
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "on-click-middle": "swaync-client -C -sw"
  },

  "cpu": {
    "interval": 5,
    "format": "C {usage}%",
    "max-length": 5,
    "on-click": "missioncenter"
  },

  "memory": {
    "interval": 5,
    "format": "M {used}G",
    "format-alt": "M {percentage}%",
    "max-length": 10,
    "on-click": "baobab"
  },

  "custom/temp": {
    "interval": 5,
    "format": " {}°C",
    "exec": "~/.config/waybar/scripts/get_temp.sh",
    "return-type": "json",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/fan_menu.sh"
  },

  "custom/power": {
    "format": "",
    "tooltip": false,
    "on-click": "~/.config/rofi/powermenu.sh"
  },

  "custom/brightness": {
    "tooltip": true,
    "interval": 5,
    "format": "󰃠 {}%",
    "exec": "brightnessctl | grep -o '[0-9]\\{1,3\\}%'",
    "tooltip-format": "{}%",
    "on-click": "~/.config/waybar/scripts/brightness.sh",
    "on-scroll-up": "brightnessctl set +5%",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "network": {
    "interface": "wlan0",
    "interval": 2,
    "format-ethernet": "󰈁  {ipaddr}",
    "tooltip-format-ethernet": "Ethernet: {ipaddr}\nDn ↓ {bandwidthDownBytes}/s Up ↑ {bandwidthUpBytes}/s",
    "format-wifi": "  {essid}",
    "tooltip-format-wifi": "WiFi: {essid}\nSignal: {signalStrength}%\nDn ↓ {bandwidthDownBytes}/s Up ↑ {bandwidthUpBytes}/s",
    "format-disconnected": "󰖪",
    "format-disconnected-tooltip": "Network Disconnected",
    "tooltip": true,
    "on-click": "nm-connection-editor",
    "max-length": 10
  },

  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 0%",
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%\nDevice: {desc}",

    "format-icons": {
      "bluetooth": "󰂯",
      "headphone": "",
      "headset": "",
      "speaker": "",
      "default": ""
    },

    "on-click": "pwvucontrol || pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
  },

  "bluetooth": {
    "interval": 1,
    "format": "󰂯",
    "tooltip": false,
    "on-click": "blueman-manager"
  },

  "custom/battery": {
    "interval": 2,
    "exec": "~/.config/waybar/scripts/battery.sh",
    "return-type": "json",
    "tooltip": true,
    "on-click-right": "~/.config/waybar/scripts/battery.sh --switch"
  },

  "clock": {
    "interval": 1,
    "format": "{:%H:%M | %a %d %b}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "niri/workspaces": {
    "on-click": "activate"
  }
}
